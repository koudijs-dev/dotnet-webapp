@page
@model IndexModel
@{
    ViewData["Title"] = "State Demo";
}

<section class="state-demo">
    <div class="state-demo__intro">
        <div>
            <p class="state-demo__eyebrow">Persistent application state</p>
            @if (!string.IsNullOrWhiteSpace(Model.EnvironmentLabel))
            {
                <p class="state-demo__env-label">@Model.EnvironmentLabel</p>
            }
            <h1>Three counters backed by Valkey</h1>
            <p class="state-demo__copy">
                Each button increments a value stored outside the app process, so the counts survive pod restarts.
            </p>
        </div>
        <img src="ict-improve-color.svg" alt="ICT Improve logo" class="state-demo__logo">
    </div>

    <div class="state-demo__meta">
        <div>
            <span class="state-demo__meta-label">Backing service</span>
            <code>@Model.BackingServiceName</code>
        </div>
        <div>
            <span class="state-demo__meta-label">State namespace</span>
            <code>@Model.RedisInstanceName</code>
        </div>
        <div>
            <span class="state-demo__meta-label">Example env var</span>
            <code>@(string.IsNullOrWhiteSpace(Model.ExampleVar) ? "not set" : Model.ExampleVar)</code>
        </div>
        <div>
            <span class="state-demo__meta-label">E-mail address</span>
            <code>@(string.IsNullOrWhiteSpace(Model.UserContext.EmailAddress) ? "not provided" : Model.UserContext.EmailAddress)</code>
        </div>
        <div>
            <span class="state-demo__meta-label">First group</span>
            <code>@(string.IsNullOrWhiteSpace(Model.UserContext.FirstGroup) ? "not provided" : Model.UserContext.FirstGroup)</code>
        </div>
        <div>
            <span class="state-demo__meta-label">Client IP</span>
            <code>@(string.IsNullOrWhiteSpace(Model.UserContext.IpAddress) ? "not provided" : Model.UserContext.IpAddress)</code>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="state-demo__message state-demo__message--success">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="state-demo__message state-demo__message--error">@Model.ErrorMessage</div>
    }

    <div class="state-demo__grid">
        @foreach (var counter in Model.Counters)
        {
            <article class="state-demo__card">
                <div>
                    <p class="state-demo__card-label">@counter.DisplayName</p>
                    <p class="state-demo__card-value">@counter.Value</p>
                </div>

                <form method="post" asp-page-handler="Increment">
                    <input type="hidden" name="counterId" value="@counter.Id">
                    <button type="submit" class="state-demo__button">Increase</button>
                </form>
            </article>
        }
    </div>
</section>
